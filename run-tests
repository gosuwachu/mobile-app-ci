#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$SCRIPT_DIR/.venv"

if [ ! -d "$VENV" ]; then
    python3 -m venv "$VENV"
fi

"$VENV/bin/pip" install --quiet -r "$SCRIPT_DIR/requirements-dev.txt"

export PYTHONPATH="$SCRIPT_DIR/src"

echo "=== mypy ==="
"$VENV/bin/mypy" src/ tests/

echo "=== pylint ==="
"$VENV/bin/pylint" src/ tests/

echo "=== vulture ==="
"$VENV/bin/vulture" src/

echo "=== pytest ==="
exec "$VENV/bin/pytest" "$@"
